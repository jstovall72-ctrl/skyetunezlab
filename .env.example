# Set these in Netlify → Site → Environment Variables

# Google Service Account (from downloaded JSON key)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nABC...\n-----END RSA PRIVATE KEY-----\n"

# Spreadsheet ID from the Google Sheets URL
GOOGLE_SHEET_ID=your_spreadsheet_id_here
